{
  "name": "invobolt",
  "version": "0.1.0",
  "private": true,
  "description": "Free, open-source invoice generator — create and export a professional invoice in seconds, no login.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "vercel-build": "node scripts/predeploy-migrate.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@neondatabase/auth": "^0.4.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.44.7",
    "next": "^16",
    "react": "^19.2",
    "react-dom": "^19.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7",
    "vitest": "^3.2.7"
  }
}
