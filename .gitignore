# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — catch every local variant (.env, .env.local, .env.production,
# .env.production.local, ...). `.env.example` is documentation, so keep it
# committable. The broad rule came from `vercel link`; it also closes a real gap,
# since `.env` + `.env*.local` alone never covered a plain `.env.production`.
.env*
!.env.example

# typescript
*.tsbuildinfo

# vercel — `vercel link` writes project/org ids here; not for a public repo
.vercel

# editor
.vscode/*
!.vscode/extensions.json
.idea
